# LATTICE Proxy Environment Configuration
# Copy this file to .env and fill in your values.

# ------------------------------------------------------------------
# Required
# ------------------------------------------------------------------
LATTICE_PROVIDER_API_KEY=sk-your-openai-key-here

# ------------------------------------------------------------------
# Optional — provider routing
# ------------------------------------------------------------------
LATTICE_PROVIDER_BASE_URL=https://api.openai.com
LATTICE_PROVIDER_BASE_URLS__OLLAMA=http://host.docker.internal:11434

# ------------------------------------------------------------------
# Session storage
# ------------------------------------------------------------------
LATTICE_SESSION_STORE=memory
# LATTICE_REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------
# Proxy settings
# ------------------------------------------------------------------
LATTICE_PROXY_PORT=8787
LATTICE_METRICS_PORT=9090
LATTICE_LOG_LEVEL=INFO
LATTICE_LOG_FORMAT=json

# ------------------------------------------------------------------
# Semantic cache
# ------------------------------------------------------------------
LATTICE_SEMANTIC_CACHE_ENABLED=true
LATTICE_SEMANTIC_CACHE_TTL_SECONDS=300
LATTICE_SEMANTIC_CACHE_MAX_ENTRIES=1000

# ------------------------------------------------------------------
# TACC congestion control
# ------------------------------------------------------------------
LATTICE_TACC_ENABLED=true
